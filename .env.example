# Atlas Trader — Environment Variables
# Copy to .env and fill in your values

# Claude / Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# News APIs
NEWSAPI_KEY=your_newsapi_key

# Broker APIs
ALPACA_API_KEY=your_alpaca_key
ALPACA_SECRET_KEY=your_alpaca_secret
ALPACA_BASE_URL=https://paper-api.alpaca.markets  # paper trading

BINANCE_API_KEY=your_binance_key
BINANCE_SECRET=your_binance_secret

OKX_API_KEY=your_okx_key
OKX_SECRET=your_okx_secret
OKX_PASSPHRASE=your_okx_passphrase

IB_HOST=127.0.0.1
IB_PORT=7497  # 7496 = live, 7497 = paper
IB_CLIENT_ID=1

# Telegram Alerts
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# Database
DUCKDB_PATH=./data/atlas.duckdb

# ---------------------------------------------------------------------------
# Social Sentiment
# ---------------------------------------------------------------------------

# Reddit (create app at https://www.reddit.com/prefs/apps — "script" type)
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=atlas-trader/1.0 by your_reddit_username
# Optional: authenticated account for higher rate limits
REDDIT_USERNAME=your_reddit_username
REDDIT_PASSWORD=your_reddit_password

# StockTwits (public API; token required for posting / higher limits)
STOCKTWITS_ACCESS_TOKEN=your_stocktwits_token

# ---------------------------------------------------------------------------
# Futu OpenD (Futu / Moomoo brokerage)
# ---------------------------------------------------------------------------
FUTU_HOST=127.0.0.1
FUTU_PORT=11111
FUTU_TRADE_ENV=1          # 0 = real money, 1 = paper/simulate
FUTU_UNLOCK_PWD=          # trading unlock password (leave blank for paper)

# ---------------------------------------------------------------------------
# Production mode flags
# ---------------------------------------------------------------------------
# Set ATLAS_ENV=production to load config/production.yaml overrides
ATLAS_ENV=paper           # paper | production

# Explicitly disable paper mode for live trading (double-safety flag)
PAPER_TRADING=true        # set to false only for live real-money trading

# Go-live date for capital deployment schedule (YYYY-MM-DD)
# Used by run_live.py to scale capital fraction week-over-week
GO_LIVE_DATE=

# ---------------------------------------------------------------------------
# Health server
# ---------------------------------------------------------------------------
HEALTH_SERVER_PORT=8080   # port exposed by the trader container healthcheck endpoint
